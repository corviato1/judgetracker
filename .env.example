# ─── CourtListener API ────────────────────────────────────────────────────────
# Get a free token at https://www.courtlistener.com/sign-in/
# Required for real judge search and opinions. Without it the backend returns
# a 503 and the frontend falls back to mock data.
COURTLISTENER_API_TOKEN=your_token_here

# ─── Backend / Frontend connection ────────────────────────────────────────────
# URL the React app uses to reach the Express backend.
# In local dev this is http://localhost:3001  (backend runs on 3001 by default)
# In production set this to your deployed backend URL.
REACT_APP_BACKEND_URL=http://localhost:3001

# ─── Optional overrides ───────────────────────────────────────────────────────
# Port for the Express backend (default: 3001)
# BACKEND_PORT=3001

# Public URL of the React frontend — used for CORS allowlist on the backend.
# FRONTEND_URL=http://localhost:5000

# ─── Database (auto-set by Replit when you provision PostgreSQL) ──────────────
# DATABASE_URL=postgres://user:password@host:5432/dbname
