# ─── CourtListener API ────────────────────────────────────────────────────────
# Get a free token at https://www.courtlistener.com/sign-in/
# Required for real judge search and opinions. Without it the backend returns
# a 503 error for judge search and opinion endpoints.
COURTLISTENER_API_TOKEN=your_token_here

# ─── Backend / Frontend connection ────────────────────────────────────────────
# URL the Vite frontend uses to reach the Express backend.
# Leave blank in local dev — Vite proxy forwards /api/* to port 3001 automatically.
# In production set this to your deployed backend URL (e.g. https://api.yoursite.com).
VITE_BACKEND_URL=

# ─── Optional overrides ───────────────────────────────────────────────────────
# Port for the Express backend (default: 3001)
# BACKEND_PORT=3001

# Public URL of the React frontend — used for CORS allowlist on the backend.
# FRONTEND_URL=http://localhost:5000

# ─── Database (auto-set by Replit when you provision PostgreSQL) ──────────────
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Email delivery (quiz results) ────────────────────────────────────────────
# When these are set, quiz result PDFs are emailed to users as attachments.
# Without them, results are saved to the DB only and users see a download prompt.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-app-password   (create at myaccount.google.com/apppasswords)
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=your-sendgrid-api-key
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
# Password for the /admin dashboard. Defaults to "carl" if not set.
ADMIN_PASSWORD=carl
# Secret used to sign the admin session cookie. Change in production.
ADMIN_SESSION_SECRET=change-me-in-production-use-a-long-random-string
